{
    "files.exclude": {
        // // Project configuration files
        // "**/package.json": true,
        // "**/vite.config.ts": true,
        // "**/index.html": true,
        // "**/README.md": true,

        // // ESLint, Prettier, Git
        // "**/eslint.config.js": true,
        // "**/.prettierrc": true,
        // "**/.prettierignore": true,
        // "**/.gitignore": true,

        // // TypeScript
        // "**/tsconfig.json": true,
        // "**/tsconfig.app.json": true,
        // "**/tsconfig.node.json": true,
        // "**/vite-env.d.ts": true,

        // // Docker
        // "**/Dockerfile*": true,
        // "**/docker-compose*.yml": true,
        // "**/.dockerignore": true,
        // "**/nginx.conf": true,

        // Generated files and dependencies
        "**/package-lock.json": true,
        "**/node_modules": true,
        "**/dist": true
    },
    // Formatting and Linting
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.eol": "\n",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.sortImports": "explicit"
    },
    "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
    // "eslint.workingDirectories": [{ "directory": "client", "changeProcessCWD": true }],

    // Imports
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "js/ts.preferences.importModuleSpecifier": "non-relative",
    "js/ts.preferences.importModuleSpecifierEnding": "minimal",

    // Emmet
    "emmet.includeLanguages": {
        "javascript": "javascriptreact",
        "typescript": "typescriptreact"
    },
    "emmet.triggerExpansionOnTab": true,

    // Tailwind CSS
    "tailwindCSS.emmetCompletions": true,
    "tailwindCSS.classFunctions": ["cn", "twMerge", "clsx"],
    "tailwindCSS.experimental.classRegex": [
        ["\\bvariants\\s*=\\s*\\{([\\s\\S]*?)\\}", "'([^']*)'"], // For variants as object
        ["\\bsizes\\s*=\\s*\\{([\\s\\S]*?)\\}", "'([^']*)'"], // For sizes as object
        ["\\bbaseStyles\\s*=\\s*'([^']*)'"], // For baseStyles as string
        ["\\bbaseStyles\\s*=\\s*\\[([\\s\\S]*?)\\]", "'([^']*)'"] // For baseStyles as array
    ],
    "editor.quickSuggestions": {
        "strings": true
    },

    "css.customData": ["./.vscode/tailwind-custom-data.json"]
}
